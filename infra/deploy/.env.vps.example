# ── Image tags ──
# Workflow upserts exact SHA image refs on every deploy.
LANDING_IMAGE=
WEB_IMAGE=
ADMIN_IMAGE=
API_IMAGE=
MODEL_API_IMAGE=
LETSENCRYPT_EMAIL=

# ── Host port binding ──
LANDING_BIND_IP=127.0.0.1
WEB_BIND_IP=127.0.0.1
ADMIN_BIND_IP=127.0.0.1
API_BIND_IP=127.0.0.1

# ── API runtime ──
# Required (must be non-empty values in production).
DATABASE_URL=
DIRECT_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_NAME=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_REFRESH_SECRET=
JWT_ACCESS_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Full URL, including scheme (e.g. https://cityfarm.id.vn/api/auth/google/callback)
GOOGLE_CALLBACK_URL=
# Full URL, including scheme (e.g. https://cityfarm.id.vn)
FRONTEND_URL=
# Comma-separated full origins, including scheme (e.g. https://cityfarm.id.vn)
WEB_ORIGINS=
# Required in production API runtime.
MODEL_API_URL=

# ── Build-time URLs (Next.js public env) ──
# Required build args for web image.
WEB_NEXT_PUBLIC_API_URL=
WEB_NEXT_PUBLIC_APP_URL=
# Required build args for admin image.
ADMIN_NEXT_PUBLIC_API_URL=
ADMIN_NEXT_PUBLIC_WEB_URL=

# ── Frontend runtime URLs (Next.js server runtime) ──
# Required in production because web/admin config now fail-fast.
NEST_API_URL=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_WEB_URL=

# ── Model API ──
# Required for Vertex AI.
GCP_PROJECT_ID=
GCP_LOCATION=
MODEL_API_GCP_KEY_FILE_ON_VPS=/root/CITYFARM-2.0/secret-key.json
MODEL_API_GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-service-account.json
# Optional when using service-account key file.
GCP_API_KEY=
