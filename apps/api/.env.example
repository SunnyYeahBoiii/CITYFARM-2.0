# NestJS listen port (nên khác 3000 nếu Next.js dùng 3000)
PORT=3001

# URL Flask model-api. Docker: http://model-api:3003 | local: http://127.0.0.1:3003
MODEL_API_URL=http://127.0.0.1:3003

#.  Connect to Supabase via connection pooling
DATABASE_URL=""

# Direct connection to the database. Used for migrations
DIRECT_URL=""

SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET_NAME=""

SUPABASE_PUBLISHABLE_KEY = ""

SUPABASE_SECRET_KEY = ""

# JWT Secrets
JWT_REFRESH_SECRET=""
JWT_ACCESS_SECRET=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL=""
FRONTEND_URL=""

# Environment (development, production)
NODE_ENV="development"
