# Environment
# development | production
NODE_ENV="development"
# Optional in development. Defaults to 3001 if omitted.
PORT=3001

# URL contract (API runtime)
# Required in production. Optional in development (defaults are used by app config).
MODEL_API_URL="http://127.0.0.1:3003"
# Required in production. Comma-separated origins with scheme.
WEB_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://127.0.0.1:3002"
# Required in production. Full frontend URL with scheme.
FRONTEND_URL="http://localhost:3000"

# Supabase / Postgres
# Required
DATABASE_URL=""
# Required (used for migrations / direct DB operations)
DIRECT_URL=""
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET_NAME=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""

# Auth
# Required
JWT_REFRESH_SECRET=""
JWT_ACCESS_SECRET=""

# Google OAuth
# Required if Google login is enabled
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL=""
