PORT=3003
FLASK_DEBUG=false

GCP_PROJECT_ID=cityfarm-494909
GCP_LOCATION=global
# Optional (prefer service-account JSON on deploy runtime)
GCP_API_KEY=

# Deploy/runtime credential path (used by docker-compose + mounted secret file)
MODEL_API_GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-service-account.json

# Backward-compatible local dev key path (relative to apps/model-api)
GCP_KEY_PATH=secret-key.json
