PORT=3003
FLASK_DEBUG=false

GCP_PROJECT_ID=cityfarm-494909
GCP_LOCATION=global
# Optional if you use API key auth
# GCP_API_KEY=

# Service-account JSON as one-line JSON string (recommended for local/.env)
# MODEL_API_SECRET_KEY_JSON={"type":"service_account","project_id":"..."}

# Optional if your secret JSON is base64-encoded
# MODEL_API_SECRET_KEY_JSON_B64=

# Optional if credentials file path is managed externally (Docker/VPS)
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-service-account.json