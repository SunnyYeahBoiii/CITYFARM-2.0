# Copy this file to .env for VPS deploy runtime (infra/deploy/docker-compose.vps.yml)
# Keep quoted values only when needed; avoid trailing spaces.

# ---- Runtime mode ----
NODE_ENV=production

# ---- API runtime ----
DATABASE_URL=
DIRECT_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_NAME=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_REFRESH_SECRET=
JWT_ACCESS_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.example.com/auth/google/callback
FRONTEND_URL=https://app.example.com
# Comma-separated origins, no spaces.
WEB_ORIGINS=https://app.example.com,https://admin.example.com
MODEL_API_URL=http://model-api:3003

# ---- Web runtime/build-time public URLs ----
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_APP_URL=https://app.example.com
# Server-side web -> api base URL (used by chat proxy route)
NEST_API_URL=http://api:3001

# ---- Admin runtime/build-time public URLs ----
NEXT_PUBLIC_WEB_URL=https://app.example.com

# ---- Model API runtime ----
GEMINI_API_KEY=
