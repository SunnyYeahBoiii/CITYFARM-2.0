# Copy this file to .env for VPS deploy runtime (infra/deploy/docker-compose.vps.yml)
# Keep quoted values only when needed; avoid trailing spaces.

# ---- Runtime mode ----
NODE_ENV=production
LETSENCRYPT_EMAIL=

# ---- API runtime ----
DATABASE_URL=
DIRECT_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_NAME=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_REFRESH_SECRET=
JWT_ACCESS_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://cityfarm.id.vn/api/auth/google/callback
FRONTEND_URL=https://cityfarm.id.vn
# Comma-separated origins, no spaces.
WEB_ORIGINS=https://cityfarm.id.vn
MODEL_API_URL=http://model-api:3003

# ---- Web runtime/build-time public URLs ----
# Primary keys used by deploy checks and docker-compose mapping.
WEB_NEXT_PUBLIC_API_URL=https://cityfarm.id.vn/api
WEB_NEXT_PUBLIC_APP_URL=https://cityfarm.id.vn
# Backward-compatible aliases (optional) used by older setups.
NEXT_PUBLIC_API_URL=https://cityfarm.id.vn/api
NEXT_PUBLIC_APP_URL=https://cityfarm.id.vn
# Server-side web -> api base URL (used by chat proxy route)
NEST_API_URL=http://api:3001

# ---- Admin runtime/build-time public URLs ----
# These ADMIN_* keys are validated by the deploy workflow.
ADMIN_NEXT_PUBLIC_API_URL=https://cityfarm.id.vn/api
ADMIN_NEXT_PUBLIC_WEB_URL=https://cityfarm.id.vn
# Backward-compatible runtime key used by admin app.
NEXT_PUBLIC_WEB_URL=https://cityfarm.id.vn

# ---- Model API runtime ----
GCP_PROJECT_ID=
GCP_LOCATION=
MODEL_API_GCP_KEY_FILE_ON_VPS=/etc/cityfarm/model-api/gcp-service-account.json
MODEL_API_GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-service-account.json
# Optional when using service-account JSON key instead of API key auth.
GCP_API_KEY=
